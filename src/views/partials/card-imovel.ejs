<article class="cardImovel">

    <span class="propriedadeTag"><%= imovel.finalidade === "venda" ? "Venda" : "Locacao" %></span>
    <img src="<%= imovel.imagem %>" alt="<%= imovel.titulo %>" />

  <div class="infoCard">
    <div class="infoLocal">
      <i class="fa-solid fa-location-dot"></i>
      <p><%= imovel.endereco %></p>
      <span><%= imovel.categoria %></span>
      <span>Cod. <%= imovel.codigo %></span>
    </div>

    <div class="nomeCard">
      <div>
        <h3><%= imovel.titulo %></h3>
        <p><%= imovel.cidade %> - <%= imovel.bairro %></p>
      </div>
      <span><i class="fa-solid fa-ruler-combined"></i> <%= imovel.area %> m²</span>
    </div>

    <div class="atributos">
      <span><i class="fa-solid fa-bed"></i> <%= imovel.quartos %></span>
      <span><i class="fa-solid fa-bath"></i> <%= imovel.banheiros %></span>
      <span><i class="fa-solid fa-car"></i> <%= imovel.vagas %></span>
    </div>

    <div class="preco">
      <strong>
        R$ <%= imovel.preco.toLocaleString("pt-BR") %>
        <%= imovel.finalidade === "locacao" ? "/mes" : "" %>
      </strong>
      <a href="/imoveis/<%= imovel.codigo %>" class="verDetalhes">Ver detalhes</a>
    </div>
  </div>
</article>